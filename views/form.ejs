<html>
  <head>
    <!-- set styling file -->
    <link rel="stylesheet" href="/styles.css">
    <title>New Message</title>
  </head>
  <body>
    <a href="/"><button>Back to Mini Messageboard</button></a>

    <h1>New Post!</h1>

    <form method="POST" action="/new">
      <input name="user" type="text" placeholder="Put your name here!">
      <input name="message" type="text" placeholder="Put you message here!">
      <button>Submit</button>
    </form>
    
    <%- include('footer') %>
  </body>
</html>